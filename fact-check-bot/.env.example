# ── Fact-Check Bot — Environment Variables ──
# Copy this file to .env and fill in your values.

# OpenAI API key (required for claim extraction + RAG verdict generation)
OPENAI_API_KEY=sk-your-openai-key-here

# Serper.dev API key (required for web evidence retrieval)
SERPER_API_KEY=your-serper-api-key-here

# GPT model to use (default: gpt-3.5-turbo)
GPT_MODEL=gpt-3.5-turbo

# Log file path
LOG_FILE=logs/checks.json

# ── CORS ──
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Social Media Ingestion ──
# Set to "true" to enable automatic Reddit/RSS monitoring
INGESTION_ENABLED=false

# Reddit OAuth credentials (get from https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=fact-check-bot/1.0
REDDIT_SUBREDDITS=worldnews+science+technology
REDDIT_POLL_INTERVAL=60
REDDIT_FETCH_LIMIT=100

# RSS feed URLs (comma-separated)
RSS_FEEDS=
RSS_POLL_INTERVAL=300

# ── Queue / Consumer ──
QUEUE_MAX_SIZE=1000
QUEUE_BATCH_SIZE=1
MAX_CONCURRENT_CHECKS=3
DEDUP_TTL_HOURS=24

# ── Retrieval System ──
FAISS_INDEX_PATH=data/faiss_index.bin
DOCUMENT_STORE_PATH=data/document_store.json
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
VECTOR_SEARCH_TOP_K=5
RERANKER_TOP_K=5
